#!/usr/bin/env npx tsx

// vim: ft=typescript

import { evalContentsS } from '../src/programs/RandomizeLang.js'

import fs from 'node:fs'

const argv = process.argv.slice(2)

argv.map((file, idx) => {
  if (idx === 0) console.log()

  const contents = fs.readFileSync(file, 'utf-8')
  const lines = evalContentsS(contents)
  console.log()
  lines.map(line => console.log(line))
})
