# Copy to `.env` (gitignored) and fill in. Both are optional at build time:
# the key can also be set at runtime via localStorage.setItem('gdriveApiKey', ...),
# and the folder ID falls back to a prompt if unset.

# Google Drive API key (browser key, restricted to the Drive API). Only reads
# files shared as "anyone with the link".
VITE_GDRIVE_API_KEY=

# Drive folder to browse for exercise files. A full folder URL or a bare ID both
# work (https://drive.google.com/drive/folders/<ID>).
VITE_GDRIVE_FOLDER_ID=
